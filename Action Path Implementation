logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


class ActionType(Enum):
    """Enumeration of executable action types"""
    PASSWORD_RESET = "password_reset"
    ACCESS_PROVISION = "access_provision"
    HARDWARE_ALLOCATION = "hardware_allocation"
    SOFTWARE_INSTALL = "software_install"
    USER_LIFECYCLE = "user_lifecycle"
    SYSTEM_MAINTENANCE = "system_maintenance"
    ORACLE_FUSION = "oracle_fusion"
    NETWORK_CONFIG = "network_config"
    SERVICE_NOW = "service_now"
    GENERAL_ACTION = "general_action"


class RiskLevel(Enum):
    """Risk classification for actions"""
    LOW = "low"           # No approval needed, auto-execute
    MEDIUM = "medium"     # Manager notification, auto-execute with logging
    HIGH = "high"         # Requires approval before execution
    CRITICAL = "critical" # Requires dual approval + security review


@dataclass
class ActionRequest:
    """Structured action request from router"""
    ticket_id: str
    raw_text: str
    action_type: ActionType
    confidence: float
    entities: Dict[str, Any] = field(default_factory=dict)
    risk_level: RiskLevel = RiskLevel.LOW
    requires_approval: bool = False
    extracted_at: datetime = field(default_factory=datetime.now)
    
    def to_dict(self) -> Dict:
        return {
            "ticket_id": self.ticket_id,
            "action_type": self.action_type.value,
            "confidence": self.confidence,
            "entities": self.entities,
            "risk_level": self.risk_level.value,
            "requires_approval": self.requires_approval
        }


@dataclass
class ActionResult:
    """Result of action execution"""
    success: bool
    message: str
    action_taken: str
    execution_time: float
    ticket_updated: bool = False
    approval_required: bool = False
    audit_log_id: Optional[str] = None
    error_details: Optional[str] = None


class EntityExtractor:
    """Extract entities from action request text"""
    
    # Patterns for entity extraction
    PATTERNS = {
        'email': r'\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b',
        'po_number': r'(?:PO|purchase order)\s*(?:#|number)?\s*:?\s*(\d+)',
        'employee_id': r'(?:emp|employee|id)\s*(?:#|number)?\s*:?\s*(\d+)',
        'system_name': r'(?:Oracle|ServiceNow|Confluence|Git|Jira|SAP|AD|Azure)\s*[A-Za-z]*',
        'project_code': r'(?:project|code)\s*(?:#|id)?\s*:?\s*([A-Z]{2,}\d{2,})',
        'date': r'\b\d{1,2}[/-]\d{1,2}[/-]\d{2,4}\b|\b(?:Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)[a-z]*\s+\d{1,2}(?:st|nd|rd|th)?\b',
        'device_type': r'\b(laptop|monitor|mouse|keyboard|headset|phone|printer|scanner|dock|cable)\b',
        'location': r'\b(?:floor|tower|building|center)\s*(?:#)?\s*:?\s*(\d+|\\w+)\b'
    }
    
    def extract(self, text: str) -> Dict[str, Any]:
        """Extract all entities from text"""
        entities = {}
        text_lower = text.lower()
        
        # Extract using regex patterns
        for entity_type, pattern in self.PATTERNS.items():
            matches = re.findall(pattern, text, re.IGNORECASE)
            if matches:
                entities[entity_type] = matches[0] if len(matches) == 1 else matches
        
        # Extract action verbs
        action_verbs = ['create', 'reset', 'change', 'update', 'install', 
                       'remove', 'delete', 'add', 'grant', 'revoke', 'allocate',
                       'purchase', 'upgrade', 'migrate', 'configure', 'enable',
                       'disable', 'extend', 'transfer', 'approve', 'request']
        
        found_verbs = [verb for verb in action_verbs if verb in text_lower]
        if found_verbs:
            entities['action_verbs'] = found_verbs
        
        # Determine target system
        if any(x in text_lower for x in ['oracle', 'fusion', 'timecard', 'expense']):
            entities['target_system'] = 'Oracle_Fusion'
        elif any(x in text_lower for x in ['service now', 'snow', 'incident']):
            entities['target_system'] = 'ServiceNow'
        elif any(x in text_lower for x in ['ad ', 'active directory', 'domain']):
            entities['target_system'] = 'Active_Directory'
        elif any(x in text_lower for x in ['confluence', 'jira', 'atlassian']):
            entities['target_system'] = 'Atlassian'
        elif any(x in text_lower for x in ['git', 'github', 'bitbucket', 'stash']):
            entities['target_system'] = 'Git_Platform'
        else:
            entities['target_system'] = 'General_IT'
        
        return entities


